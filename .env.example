# Database (required)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# App URL (production — used for magic links & OAuth callbacks)
# In GitHub Codespaces this is auto-detected via CODESPACE_NAME + GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Magic link email (optional — without this, dev mode shows link on screen)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="MsgNexus.AI <onboarding@resend.dev>"

# Gmail OAuth (optional — enables real email import in Settings)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft / Outlook OAuth (optional)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Slack OAuth
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Discord OAuth
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""

# WhatsApp Business (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""

# X / Twitter OAuth 2.0
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# Vercel Cron auth (optional — secures /api/cron/sync)
CRON_SECRET=""